# Get active user via WMI
$activeUser = (Get-CimInstance Win32_ComputerSystem).UserName

if (-not $activeUser) {
    Write-Output "Active user not found"
    exit
}

Write-Output "Active user: $activeUser"

# Get user SID
try {
    $ntAccount = New-Object System.Security.Principal.NTAccount($activeUser)
    $sid = $ntAccount.Translate([System.Security.Principal.SecurityIdentifier]).Value
} catch {
    Write-Output "Failed to resolve user SID"
    exit
}

Write-Output "User SID: $sid"

# Edge path
$edgePath = "$env:ProgramFiles (x86)\Microsoft\Edge\Application\msedge.exe"
if (-not (Test-Path $edgePath)) {
    $edgePath = "$env:ProgramFiles\Microsoft\Edge\Application\msedge.exe"
}

if (-not (Test-Path $edgePath)) {
    Write-Output "Microsoft Edge executable not found"
    exit
}

# Ensure user hive is loaded
if (-not (Test-Path "Registry::HKEY_USERS\$sid")) {
    Write-Output "User hive not loaded, attempting to load"

    $profilePath = (Get-CimInstance Win32_UserProfile | Where-Object {$_.SID -eq $sid}).LocalPath
    if ($profilePath) {
        reg load "HKU\$sid" "$profilePath\NTUSER.DAT" | Out-Null
    } else {
        Write-Output "User profile path not found"
    }
}

$runKeyUser = "Registry::HKEY_USERS\$sid\Software\Microsoft\Windows\CurrentVersion\Run"
$runKeyMachine = "Registry::HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\Run"

$created = $false

# Try HKU
try {
    if (-not (Test-Path $runKeyUser)) {
        New-Item -Path $runKeyUser -Force | Out-Null
    }

    New-ItemProperty -Path $runKeyUser `
        -Name "EdgeAutoStart" `
        -Value "`"$edgePath`"" `
        -PropertyType String `
        -Force | Out-Null

    Write-Output "Autorun entry created under HKU\$sid"
    $created = $true
}
catch {
    Write-Output "Failed to create autorun entry in HKU: $_"
}

# Fallback to HKLM
if (-not $created) {
    try {
        New-ItemProperty -Path $runKeyMachine `
            -Name "EdgeAutoStart" `
            -Value "`"$edgePath`"" `
            -PropertyType String `
            -Force | Out-Null

        Write-Output "Autorun entry created under HKLM"
    }
    catch {
        Write-Output "Failed to create autorun entry in HKLM: $_"
    }
}

