$imageUrl = "https://raw.githubusercontent.com/kolomka-cpu/elka/refs/heads/main/m.jpeg"
$imagePath = "$env:TEMP\wallpaper.jpg"
$scrPath = "$env:TEMP\screensaver.scr"

try {
    Write-Host "loading..." -ForegroundColor Yellow
    Invoke-WebRequest -Uri $imageUrl -OutFile $imagePath -UseBasicParsing
    
    @"
Windows Registry Editor Version 5.00

[HKEY_CURRENT_USER\Control Panel\Desktop]
"Wallpaper"="$imagePath"
"SCRNSAVE.EXE"="C:\Windows\System32\sspic64.scr"
"$imagePath"=-
"@ | Out-File "$env:TEMP\wallpaper.reg" -Encoding ASCII
    
    reg import "$env:TEMP\wallpaper.reg"
    
    Start-Sleep -Seconds 1
    rundll32.exe user32.dll,UpdatePerUserSystemParameters
    
    Write-Host "installed!" -ForegroundColor Green
}
catch {
    Write-Host "error: $_" -ForegroundColor Red
}
