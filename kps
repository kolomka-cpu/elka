$imageUrl = "https://raw.githubusercontent.com/kolomka-cpu/elka/refs/heads/main/m.jpeg"
$imagePath = "$env:TEMP\wallpaper.jpg"

try {
    Write-Host "Loading..." -ForegroundColor Yellow
    Invoke-WebRequest -Uri $imageUrl -OutFile $imagePath -UseBasicParsing
    
    Write-Host "Setting wallpaper..." -ForegroundColor Yellow
    
    Add-Type @"
using System;
using System.Runtime.InteropServices;
using Microsoft.Win32;
namespace Wallpaper
{
    public class Setter
    {
        [DllImport("user32.dll", CharSet = CharSet.Auto)]
        private static extern int SystemParametersInfo(int uAction, int uParam, string lpvParam, int fuWinIni);
        
        [DllImport("user32.dll")]
        private static extern bool UpdatePerUserSystemParameters(IntPtr pvParam, bool fAsync, int nMsg);
        
        public static void SetWallpaper(string path)
        {
            SystemParametersInfo(20, 0, path, 3);
            UpdatePerUserSystemParameters(IntPtr.Zero, true, 0);
        }
    }
}
"@

    [Wallpaper.Setter]::SetWallpaper($imagePath)
    
    try {
        Set-ItemProperty -Path "HKCU:\Control Panel\Desktop" -Name "Wallpaper" -Value $imagePath -ErrorAction SilentlyContinue
        Set-ItemProperty -Path "HKCU:\Control Panel\Desktop" -Name "WallpaperStyle" -Value "2" -ErrorAction SilentlyContinue  # 2 = растянуть
        Set-ItemProperty -Path "HKCU:\Control Panel\Desktop" -Name "TileWallpaper" -Value "0" -ErrorAction SilentlyContinue
    } catch {}
    
    # Get-Process explorer | Stop-Process -Force
    
    Write-Host "Done! Wallpaper has been set." -ForegroundColor Green
    Write-Host "Image path: $imagePath" -ForegroundColor Cyan
}
catch {
    Write-Host "Error: $_" -ForegroundColor Red
}
