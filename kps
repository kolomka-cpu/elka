$imageUrl = "https://raw.githubusercontent.com/kolomka-cpu/elka/refs/heads/main/m.jpeg"
$imagePath = "$env:TEMP\wallpaper.jpg"
$scriptPath = "$env:TEMP\apply_wallpaper.ps1"

try {
    Write-Host "Loading..." -ForegroundColor Yellow
    Invoke-WebRequest -Uri $imageUrl -OutFile $imagePath -UseBasicParsing

    Write-Host "Creating apply script..." -ForegroundColor Yellow

    # Создаём скрипт для применения (с правильным экранированием)
    @"
`$imagePath = "$imagePath"

# Установка через реестр
Set-ItemProperty -Path "HKCU:\Control Panel\Desktop" -Name "Wallpaper" -Value `$imagePath -Type String -Force
Set-ItemProperty -Path "HKCU:\Control Panel\Desktop" -Name "WallpaperStyle" -Value "2" -Type String -Force
Set-ItemProperty -Path "HKCU:\Control Panel\Desktop" -Name "TileWallpaper" -Value "0" -Type String -Force

# Добавляем WinAPI функцию
Add-Type -TypeDefinition @"
using System;
using System.Runtime.InteropServices;
public class WallpaperApplier {
    [DllImport("user32.dll", CharSet = CharSet.Auto)]
    public static extern int SystemParametersInfo(int uAction, int uParam, string lpvParam, int fuWinIni);
}
"@

# Применяем обои
[WallpaperApplier]::SystemParametersInfo(20, 0, `$imagePath, 3)

Write-Host "Wallpaper applied in user session!" -ForegroundColor Green
"@ | Out-File $scriptPath -Encoding ASCII

    Write-Host "Creating scheduled task..." -ForegroundColor Yellow

    # Получаем имя текущего пользователя
    $currentUser = (Get-CimInstance -ClassName Win32_ComputerSystem).UserName

    # Создаём задание в планировщике
    $taskName = "ApplyWallpaperTask_$(Get-Random)"
    $action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -File `"$scriptPath`""
    $trigger = New-ScheduledTaskTrigger -AtLogOn -User $currentUser
    $settings = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -StartWhenAvailable
    $principal = New-ScheduledTaskPrincipal -UserId $currentUser -LogonType Interactive -RunLevel Limited

    Register-ScheduledTask -TaskName $taskName -Action $action -Trigger $trigger -Settings $settings -Principal $principal -Force

    Write-Host "Task created. It will apply at next user logon." -ForegroundColor Green
    Write-Host "Task name: $taskName" -ForegroundColor Cyan
}
catch {
    Write-Host "Error: $_" -ForegroundColor Red
    Write-Host "Line: $($_.InvocationInfo.ScriptLineNumber)" -ForegroundColor Red
}
